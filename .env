DATABASE_URL=postgresql://postgres:password@db:5432/farm2fork
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.2.0

CUSTOMER_MODULE_BASE_URL=http://159.203.16.186:3000
CUSTOMER_MODULE_CUSTOMER_LOOKUP_PATH=/customers/{customer_id}
CUSTOMER_MODULE_TIMEOUT_SECONDS=5.0

DRIVER_SERVICE_BASE_URL=http://driver-service:8000
DRIVER_SERVICE_DRIVERS_PATH=/api/drivers
DRIVER_SERVICE_TIMEOUT_SECONDS=5.0
DRIVER_SERVICE_ENABLE_DEV_FALLBACK=false
DRIVER_AUTH_DEFAULT_VEHICLE_TYPE=Delivery Van

FRONTEND_ALLOWED_ORIGINS=*

VALHALLA_ENABLE_ROUTING=false
VALHALLA_BASE_URL=http://host.docker.internal:8002
OSRM_ENABLE_ROUTING=true
OSRM_BASE_URL=https://router.project-osrm.org

WAREHOUSE_NAME=Farm2Fork Warehouse
WAREHOUSE_STREET=108 University Ave E
WAREHOUSE_CITY=Waterloo
WAREHOUSE_PROVINCE=ON
WAREHOUSE_POSTAL_CODE=N2J 2W2
WAREHOUSE_COUNTRY=Canada
WAREHOUSE_LATITUDE=43.4790290
WAREHOUSE_LONGITUDE=-80.5179320

PLANNING_TIMEZONE=America/Toronto
PLANNING_WORKDAY_START_HOUR=9
PLANNING_WORKDAY_END_HOUR=17
PLANNING_DRIVER_COUNT=100
PLANNING_TRUCK_COUNT=100
PLANNING_MAX_ORDERS_PER_ROUTE=50
PLANNING_AUTO_ASSIGN_DRIVERS=false

INTAKE_AUTO_SYNC_CUSTOMER=true
INTAKE_AUTO_SCHEDULE=true

DRIVER_AUTH_ACCEPT_UNSIGNED_TOKENS=true
DEMO_DATA_AUTO_SEED=false
CUSTOMER_STATUS_CALLBACK_ENABLED=false
CUSTOMER_STATUS_CALLBACK_BASE_URL=
CUSTOMER_STATUS_CALLBACK_PATH=/api/orders/{order_id}/delivery-status
CUSTOMER_STATUS_CALLBACK_TIMEOUT_SECONDS=5.0

NEXT_PUBLIC_API_BASE_URL=

INTERNAL_API_BASE_URL=http://app:8000
